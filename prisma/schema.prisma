generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  OWNER
  RENTER
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  NOT_SUBMITTED
}

enum DocumentType {
  PASSPORT
  ID_CARD
  DRIVER_LICENSE
}

enum VehicleCategory {
  ECONOMY
  SEDAN
  SUV
  PREMIUM
  VAN
  ELECTRIC
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  GAS
}

enum VehicleStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  REJECTED
  INACTIVE
}

enum BookingStatus {
  PENDING_PAYMENT
  PENDING_OWNER_APPROVAL
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
  DISPUTED
}

enum BookingType {
  DAILY
  MONTHLY
}

enum BookingPaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum PaymentType {
  RENTAL_PAYMENT
  DEPOSIT_HOLD
  REFUND
  PAYOUT
}

enum PaymentMethod {
  UZCARD
  HUMO
  CLICK
  PAYME
  VISA
  MASTERCARD
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  HELD
  RELEASED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  phone             String
  passwordHash      String
  role              Role
  avatarUrl         String?
  bio               String?
  city              String
  kycStatus         KycStatus      @default(NOT_SUBMITTED)
  isSuspended       Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  kycDocuments      KycDocument[]
  ownedVehicles     Vehicle[]      @relation("VehicleOwner")
  bookingsAsRenter  Booking[]      @relation("BookingRenter")
  bookingsAsOwner   Booking[]      @relation("BookingOwner")
  payments          Payment[]
  reviewsAuthored   Review[]       @relation("ReviewAuthor")
  reviewsReceived   Review[]       @relation("ReviewReceiver")
  messagesSent      Message[]      @relation("MessageSender")
  messagesReceived  Message[]      @relation("MessageReceiver")
  notifications     Notification[]
  disputesOpened    Dispute[]      @relation("DisputeOpenedBy")
  favorites         Favorite[]

  @@index([role, kycStatus])
}

model KycDocument {
  id              String       @id @default(cuid())
  userId          String
  documentType    DocumentType
  frontImageUrl   String
  backImageUrl    String?
  status          KycStatus    @default(PENDING)
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Vehicle {
  id                 String            @id @default(cuid())
  ownerId            String
  make               String
  model              String
  year               Int
  category           VehicleCategory
  transmission       Transmission
  fuelType           FuelType
  seats              Int
  city               String
  address            String
  latitude           Float?
  longitude          Float?
  dailyPrice         Int
  monthlyPrice       Int?
  depositAmount      Int
  description        String
  rules              String
  mileageLimitPerDay Int
  plateNumber        String
  hasOsago           Boolean
  hasCasco           Boolean          @default(false)
  airportPickupAvailable Boolean      @default(false)
  deliveryAvailable  Boolean          @default(false)
  monthlyAvailable   Boolean          @default(false)
  instantBook        Boolean          @default(false)
  pickupInstructions String?
  deliveryFee        Int?
  status             VehicleStatus    @default(DRAFT)
  rejectionReason    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  owner              User             @relation("VehicleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  photos             VehiclePhoto[]
  availabilityBlocks AvailabilityBlock[]
  bookings           Booking[]
  reviews            Review[]
  favorites          Favorite[]

  @@index([city, status])
  @@index([ownerId, status])
  @@index([category, transmission, fuelType])
}

model VehiclePhoto {
  id        String   @id @default(cuid())
  vehicleId String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, sortOrder])
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  vehicleId String
  startDate DateTime
  endDate   DateTime
  reason    String
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, startDate, endDate])
}

model Booking {
  id                 String               @id @default(cuid())
  vehicleId          String
  renterId           String
  ownerId            String
  startDate          DateTime
  endDate            DateTime
  days               Int
  bookingType        BookingType          @default(DAILY)
  durationMonths     Int?
  dailyPrice         Int
  monthlyPrice       Int?
  rentalAmount       Int
  serviceFee         Int
  depositAmount      Int
  totalAmount        Int
  deliveryFee        Int                  @default(0)
  status             BookingStatus       @default(PENDING_PAYMENT)
  paymentStatus      BookingPaymentStatus @default(UNPAID)
  pickupLocation     String?
  startTime          String?
  endTime            String?
  pickupNotes        String?
  returnNotes        String?
  cancellationReason String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  vehicle            Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  renter             User                @relation("BookingRenter", fields: [renterId], references: [id], onDelete: Cascade)
  owner              User                @relation("BookingOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  payments           Payment[]
  reviews            Review[]
  messages           Message[]
  disputes           Dispute[]

  @@index([vehicleId, startDate, endDate])
  @@index([renterId, status])
  @@index([ownerId, status])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  vehicleId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([userId, createdAt])
  @@index([vehicleId, createdAt])
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String
  userId            String
  amount            Int
  type              PaymentType
  method            PaymentMethod
  status            PaymentStatus
  providerReference String
  createdAt         DateTime      @default(now())
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId, type])
  @@index([userId, status])
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String
  vehicleId  String
  authorId   String
  receiverId String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReviewReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([bookingId, authorId])
  @@index([vehicleId, rating])
}

model Message {
  id            String   @id @default(cuid())
  bookingId     String?
  senderId      String
  receiverId    String
  content       String
  attachmentUrl String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  sender        User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([receiverId, isRead])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model Dispute {
  id          String        @id @default(cuid())
  bookingId   String
  openedById  String
  reason      String
  description String
  status      DisputeStatus @default(OPEN)
  adminNote   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  openedBy    User          @relation("DisputeOpenedBy", fields: [openedById], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([bookingId])
}
